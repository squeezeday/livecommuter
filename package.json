  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "gtfs-realtime-bindings": "^1.1.1",
    "leaflet": "^1.9.4",
    "node-fetch": "^3.3.2",
    "protobufjs": "^8.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0-rc.2"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:docker": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --inspect=0.0.0.0:9230 src/server/main.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:server": "node esbuild.config.js",
    "build:client": "vite build",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "type-check": "tsc --noEmit"
  }
}
